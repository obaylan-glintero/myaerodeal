# N8N Environment Variables for Aircraft Lead Matcher
# Copy this file to .env and fill in your values

# Supabase Configuration
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Email Configuration
NOTIFICATION_EMAIL=your-email@example.com

# Telegram Configuration (Optional)
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# Gmail Configuration
# These are set up via OAuth2 in n8n, no env vars needed
# Just keep note of your Google Cloud Project credentials

# Workflow Schedule
SCHEDULE_HOUR=8  # 0-23, default is 8 AM

# Matching Configuration
MIN_MATCH_SCORE=50  # Minimum score to be considered a match (0-100)
MAX_EMAILS_TO_PROCESS=50  # Maximum emails to fetch per run
